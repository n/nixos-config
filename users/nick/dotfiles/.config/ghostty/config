# Theme
background-opacity = 0.95
background-blur = 20

# Infinite scrollback
scrollback-limit = 10_000_000_000

# Quick terminal
keybind = global:cmd+shift+grave_accent=toggle_quick_terminal

# Fix CPU issue in Linux
#async-backend = epoll

# Fix border when window size is not a multiple of cell size
window-padding-balance = true
window-padding-color = extend

# Claude Code
keybind = shift+enter=text:\n

# Disable warnings
clipboard-paste-protection = false
confirm-close-surface = false

# Command finish notifications
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

command = /etc/profiles/per-user/nick/bin/fish
